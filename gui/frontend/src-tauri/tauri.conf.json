{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/tauri-v2.1.0/crates/tauri-cli/schema.json",
  "productName": "RLinf Studio",
  "version": "0.1.0",
  "identifier": "com.rlinf.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "RLinf Studio",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src http://localhost:18721 ws://localhost:18721; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../backend/main.py": "backend/main.py",
      "../../backend/config.py": "backend/config.py",
      "../../backend/__init__.py": "backend/__init__.py",
      "../../backend/api/": "backend/api/",
      "../../backend/services/": "backend/services/",
      "../../backend/models/": "backend/models/",
      "../../backend/pyproject.toml": "backend/pyproject.toml"
    },
    "linux": {
      "deb": {
        "depends": ["python3 (>= 3.10)", "python3-venv", "python3-pip"],
        "section": "science",
        "desktopTemplate": null
      }
    }
  }
}
